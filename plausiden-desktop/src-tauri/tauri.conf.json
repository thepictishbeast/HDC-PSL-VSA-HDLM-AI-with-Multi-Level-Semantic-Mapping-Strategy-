{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PlausiDen AI",
  "version": "0.1.0",
  "identifier": "com.plausiden.ai",
  "build": {
    "frontendDist": "/root/LFI/lfi_dashboard/dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd /root/LFI/lfi_dashboard && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PlausiDen AI",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:3000 ws://localhost:3000; style-src 'self' 'unsafe-inline'; script-src 'self'"
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/thepictishbeast/PlausiDen-Desktop/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
